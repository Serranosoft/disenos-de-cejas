{
    "expo": {
        "name": "Diseño de cejas",
        "slug": "como-hacer-cejas",
        "version": "2.0.1",
        "orientation": "portrait",
        "icon": "./assets/logo-cejas.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": false,
        "splash": {
            "image": "./assets/splash-cejas.png",
            "resizeMode": "contain",
            "backgroundColor": "#FFECF4"
        },
        "scheme": "como-hacer-cejas",
        "assetBundlePatterns": [
            "**/*"
        ],
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.paulaymanu113.comohacercejas",
            "buildNumber": "7",
            "infoPlist": {
                "ITSAppUsesNonExemptEncryption": false,
                "NSPhotoLibraryUsageDescription": "La app accede a tus fotos para permitirte guardar tus diseños de cejas personalizados.",
                "NSCameraUsageDescription": "Permitir a la app usar la cámara para la función de simetría y diseño de cejas.",
                "NSUserTrackingUsageDescription": "Este identificador se utilizará para ofrecerte anuncios personalizados sobre diseño y estética de cejas según tus intereses."
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./assets/logo-cejas.png",
                "backgroundColor": "#FFECF4"
            },
            "versionCode": 13,
            "package": "com.paulaymanu113.comohacercejas",
            "permissions": [
                "android.permission.RECORD_AUDIO"
            ]
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "extra": {
            "eas": {
                "projectId": "be318d56-3aa9-4961-aadf-bfcffa31c32b"
            }
        },
        "plugins": [
            "expo-router",
            [
                "react-native-google-mobile-ads",
                {
                    "androidAppId": "ca-app-pub-3738413299329691~4726584588",
                    "iosAppId": "ca-app-pub-3738413299329691~4726584588",
                    "delayAppMeasurementInit": true,
                    "userTrackingUsageDescription": "Este identificador se utilizará para ofrecerte anuncios personalizados sobre diseño y estética de cejas según tus intereses."
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "The app accesses your photos to let you share them with your friends."
                }
            ],
            [
                "expo-camera",
                {
                    "cameraPermission": "Permitir a la app usar la cámara para la función de simetría y diseño."
                }
            ],
            [
                "expo-build-properties",
                {
                    "android": {
                        "extraProguardRules": "-keep class com.google.android.gms.internal.consent_sdk.** { *; }"
                    }
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification.png"
                }
            ],
            [
                "expo-font",
                {
                    "android": {
                        "fonts": [
                            {
                                "fontFamily": "Changa",
                                "fontDefinitions": [
                                    {
                                        "path": "./assets/fonts/Changa/Changa.ttf",
                                        "weight": "400",
                                        "style": "normal"
                                    }
                                ]
                            },
                            {
                                "fontFamily": "Slabo",
                                "fontDefinitions": [
                                    {
                                        "path": "./assets/fonts/Slabo/Slabo.ttf",
                                        "weight": "400",
                                        "style": "normal"
                                    }
                                ]
                            }
                        ]
                    },
                    "ios": {
                        "fonts": [
                            "./assets/fonts/Changa/Changa.ttf",
                            "./assets/fonts/Slabo/Slabo.ttf"
                        ]
                    }
                }
            ],
            "expo-localization",
            "expo-tracking-transparency"
        ]
    }
}